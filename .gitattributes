# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Force specific file types to LF (even on Windows checkout)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git
.gitattributes text eol=lf
.gitignore text eol=lf

# Binary files (no line-ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
