# config/template.env — schema for forking this repo to a new operator.
#
# Copy this to config/<env>.env (e.g. config/production.env) and fill in:
#
#   1. Identity values (WORKER_NAME, CF_SUBDOMAIN, OPERATOR_EMAIL).
#   2. Run `mise run cf:provision` — creates D1 + R2, writes IDs back here.
#   3. Run `mise run cf:access:setup` — creates Access App + allow policy,
#      writes TEAM_DOMAIN + AUD to fnox.
#   4. Run `mise run secrets:put-cf` — pushes 4 secrets from fnox to Worker.
#   5. Run `mise run 10-deploy`.
#   6. Run `mise run prove:all`.
#
# Every mise task accepts `-- --env <env>` to switch which config file
# it reads. Default is `production`.
#
# DO NOT COMMIT a filled-out config/<env>.env. They're gitignored.
# Real secrets live in fnox keychain, not this file.

# ── Identity ─────────────────────────────────────────────────────────────────

# Cloudflare Worker name (must be unique in your CF account).
WORKER_NAME=kv-manager

# Your *.workers.dev subdomain (the part before .workers.dev).
CF_SUBDOMAIN=

# ── Cloudflare resources (set by `mise run cf:provision`) ────────────────────

# kv-manager's metadata D1 database.
METADATA_DB_NAME=kv-manager-metadata
METADATA_DB_ID=

# R2 bucket for snapshots / exports.
BACKUP_BUCKET_NAME=kv-manager-backups

# ── Cloudflare Access (auto-resolved by `cf:access:setup` from fnox) ────────
#
# Stored in fnox under canonical names:
#   CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID  — operator-level, shared
#   CF_ACCESS_TEAM_DOMAIN, CF_ACCESS_GITHUB_IDP_ID — operator-level, shared
#   KV_MANAGER_POLICY_AUD                        — app-specific, set by cf:access:setup

# ── Operator identity ───────────────────────────────────────────────────────

# Email allowed to access the kv-manager UI through CF Access. cf:access:setup
# adds an allow-by-email policy for this address. Multiple emails: comma-
# separate (no spaces). If empty, no policy is created — login 403s after
# OAuth, prove:access:policy will catch this.
OPERATOR_EMAIL=

# Subset of fnox keys that should also sync to GitHub Actions secrets
# (only matters if CI deploys this fork). Empty = no sync.
FNOX_SYNC_KEYS=
